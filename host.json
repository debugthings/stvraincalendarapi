{
    "version": "2.0",
    "telemetryMode": "OpenTelemetry",
    "logging": {
      "OpenTelemetry": {
        "logLevel": {
          "Default": "Information",
          "StVrainToICSFunctionApp": "Information"
        }
      },
      "applicationInsights": {
        "samplingSettings": {
          "isEnabled": true,
          "excludedTypes": "Request"
        },
        "enableLiveMetricsFilters": true
      }
    }
}